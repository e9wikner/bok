# Bokföringssystem API - Environment Configuration
# Copy this file to .env and adjust values for your environment

# API Configuration
BOKFOERING_API_KEY=dev-key-change-in-production
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
DEBUG=False

# Database
DATABASE_URL=sqlite:///./bokfoering.db

# API Server (optional)
API_HOST=127.0.0.1
API_PORT=8000

# Logging (future)
LOG_LEVEL=INFO

# Features (future)
ENABLE_VAT_REPORTING=True
ENABLE_K2_EXPORT=True
