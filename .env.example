# Bokföringssystem API - Environment Configuration
# Copy this file to .env and adjust values for your environment

# API Configuration
BOKFOERING_API_KEY=dev-key-change-in-production
DEBUG=False

# Database
DATABASE_URL=sqlite:///./bokfoering.db

# API Server (optional)
API_HOST=127.0.0.1
API_PORT=8000

# Multi-tenancy (set to true to enable multiple companies)
MULTI_TENANT=false
TENANT_DATA_DIR=/app/data/tenants
# DEFAULT_TENANT_ID=default

# Admin API key (required to create/manage tenants via REST API)
# Generate with: openssl rand -hex 32
# ADMIN_API_KEY=

# Logging (future)
LOG_LEVEL=INFO

# Features (future)
ENABLE_VAT_REPORTING=True
ENABLE_K2_EXPORT=True
