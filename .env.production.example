# Production Environment Configuration
# Copy to .env.production and fill in your values

# ==========================================
# REQUIRED: API Configuration
# ==========================================

# Secure API key (generate with: openssl rand -hex 32)
API_KEY=change-this-to-secure-random-key

# Login credentials for the web UI
AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-to-secure-password

# Database location (SQLite)
DATABASE_URL=sqlite:////app/data/bokfoering.db

# Debug mode (MUST be False for production)
DEBUG=False

# ==========================================
# REQUIRED: Frontend Configuration
# ==========================================

# Backend API URL (used by frontend)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Frontend API key (same as API_KEY above)
NEXT_PUBLIC_API_KEY=change-this-to-secure-random-key

# ==========================================
# OPTIONAL: Domain Configuration
# ==========================================

# Domain for API endpoint
API_DOMAIN=api.yourdomain.com

# Domain for frontend application
APP_DOMAIN=app.yourdomain.com

# Domain for legacy Streamlit frontend (optional)
LEGACY_DOMAIN=legacy.yourdomain.com

# Email for Let's Encrypt SSL certificates
LETSENCRYPT_EMAIL=admin@yourdomain.com

# ==========================================
# OPTIONAL: CORS & Security
# ==========================================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# Session secret (generate with: openssl rand -hex 32)
# SESSION_SECRET=your-session-secret-here

# ==========================================
# OPTIONAL: Backup Configuration
# ==========================================

# AWS credentials for S3 backup (optional)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET_NAME=your-backup-bucket
# AWS_S3_ENDPOINT=s3.eu-central-1.amazonaws.com

# ==========================================
# OPTIONAL: Monitoring (Grafana)
# ==========================================

# Grafana admin password
# GRAFANA_PASSWORD=secure-grafana-password

# ==========================================
# OPTIONAL: Rate Limiting
# ==========================================

# Requests per minute per IP
# RATE_LIMIT_PER_MINUTE=60

# ==========================================
# OPTIONAL: Logging
# ==========================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable file logging
LOG_TO_FILE=True
LOG_FILE_PATH=/app/logs/bokfoering.log

# ==========================================
# SECURITY WARNING
# ==========================================
# NEVER commit this file to git!
# This file contains sensitive credentials.
# Make sure .env.production is in .gitignore
# ==========================================